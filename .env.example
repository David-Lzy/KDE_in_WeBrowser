# Compose project
COMPOSE_PROJECT_NAME=kde-in-web-browser
CONTAINER_NAME=kde-webtop
WEBTOP_IMAGE=kde-webtop:wechat-qq
NGINX_IMAGE=nginx:mainline-alpine
FRPC_IMAGE=snowdreamtech/frpc:nightly

# Host user and project-local desktop home. HOST_HOME is mounted to /config.
HOST_USER=davidli
HOST_UID=1000
HOST_GID=1000
HOST_HOME=../data/home/davidli
CONTAINER_USER=docker_davidli
CONTAINER_HOSTNAME=docker_host

# Network exposure detection
NETWORK_EXPOSURE=unknown
NETWORK_EXPOSURE_REASON=not_detected
NETWORK_ROUTE_IPV4=
NETWORK_ROUTE_IFACE=
NETWORK_PUBLIC_IPV4=
NETWORK_PUBLIC_IP_SERVICE=https://api.ipify.org
NETWORK_DEFAULT_SSLIP_DOMAIN=
NETWORK_PORT_80_STATE=unknown
NETWORK_PORT_443_STATE=unknown

# Container user
TZ=Australia/Adelaide
WEBTOP_LANG=zh_CN.UTF-8
WEBTOP_LANGUAGE=zh_CN
WEBTOP_LC_ALL=zh_CN.UTF-8
TITLE=KDE in Web Browser

# Display and GPU
SHM_SIZE=2gb
DRI_DEVICE=/dev/dri
DRINODE=/dev/dri/renderD128
DRI_NODE=/dev/dri/renderD128
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
PIXELFLUX_WAYLAND=true
AUTO_GPU=true

# Selkies clipboard and scaling
SELKIES_CLIPBOARD_ENABLED=true
SELKIES_CLIPBOARD_IN_ENABLED=true
SELKIES_CLIPBOARD_OUT_ENABLED=true
SELKIES_ENABLE_BINARY_CLIPBOARD=true
SELKIES_COMMAND_ENABLED=true
SELKIES_USE_CSS_SCALING=false
SELKIES_FORCE_ALIGNED_RESOLUTION=true
SELKIES_SCALING_DPI=96,120,144,168,192,216,240,264,288
ENABLE_AUTO_HIDPI_DPI=true

# Selkies video and bandwidth controls. This is the balanced preset.
SELKIES_ENCODER=x264enc,jpeg
SELKIES_FRAMERATE=8-60
SELKIES_VIDEO_BITRATE=8
SELKIES_RATE_CONTROL_MODE=cbr
SELKIES_ENABLE_RATE_CONTROL=true
SELKIES_H264_CRF=18-35
SELKIES_JPEG_QUALITY=80
SELKIES_AUDIO_BITRATE=128000
SELKIES_USE_PAINT_OVER_QUALITY=true
SELKIES_PAINT_OVER_JPEG_QUALITY=90
SELKIES_H264_PAINTOVER_CRF=18-28
SELKIES_H264_PAINTOVER_BURST_FRAMES=5

# Keep this on so Wayland and Xwayland apps share text clipboard content.
ENABLE_XWAYLAND_CLIPBOARD_BRIDGE=true

# Terminal integration
ENABLE_TERMINAL_INTEGRATION=true
HOST_SSH_HOST=host.docker.internal
HOST_SSH_PORT=10198
HOST_SSH_TARGET=
HOST_SSH_KEY=/config/.ssh/kde-webtop-host-ed25519
SYNC_HOST_TERMINAL_ASSETS=true
SYNC_HOST_TERMINAL_SYSTEM_FONT_MATCHES=true

# Browser dark/light preference to KDE theme sync
ENABLE_THEME_SYNC=true
THEME_SYNC_LIGHT_SCHEME=BreezeLight
THEME_SYNC_DARK_SCHEME=BreezeDark
THEME_SYNC_LIGHT_LOOK_AND_FEEL=org.kde.breeze.desktop
THEME_SYNC_DARK_LOOK_AND_FEEL=org.kde.breezedark.desktop

# WeChat/QQ module.
ENABLE_WECHAT_QQ_MODULE=true
INSTALL_WECHAT=true
INSTALL_QQ=true
INSTALL_PCMANFM=true
AUTO_START_WECHAT=false
AUTO_START_QQ=false
WECHAT_PROFILE_DIR=../data/wechat/.xwechat
WECHAT_FILES_DIR=../data/wechat/xwechat_files
QQ_DATA_DIR="../data/qq/Tencent Files"

# Auth gateway
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=18080
GATEWAY_PUBLIC_BASE_URL=https://127.0.0.1:18080
GATEWAY_AUTH_PROVIDER=pam
GATEWAY_AUTH_INTERNAL_URI=/internal/pam/authz
GATEWAY_TLS_CERT=../ssl/kde-webtop.crt
GATEWAY_TLS_KEY=../ssl/kde-webtop.key
GATEWAY_TLS_SANS=IP:127.0.0.1,DNS:localhost

# Public ACME / Let's Encrypt. Disabled by default.
ACME_ENABLED=false
ACME_PROVIDER=sslip
ACME_DOMAIN=
ACME_EMAIL=
ACME_CERT_NAME=
ACME_HTTP_PORT=80
ACME_STAGING=false
ACME_ALLOW_NO_EMAIL=false
ACME_AUTO_RENEW=true
PAM_AUTH_RUN_DIR=../data/pam-auth/run
PAM_AUTH_STATE_DIR=../data/pam-auth/state
PAM_AUTH_SOCKET_CONTAINER=/run/kde-pam-auth/pam-helper.sock
PAM_AUTH_SERVICE=kde-webtop
PAM_AUTH_ALLOWED_USERS=davidli
PAM_AUTH_SESSION_TTL_SECONDS=86400
PAM_AUTH_COOKIE_NAME=kde_pam_session
AUTHELIA_VERSION=4.39.20
AUTHELIA_CONFIG_DIR=../data/authelia
AUTHELIA_PUBLIC_BASE_URLS=https://127.0.0.1:18080
AUTHELIA_USER=davidli
AUTHELIA_DISPLAY_NAME=KDE Web Desktop
AUTHELIA_EMAIL=davidli@localhost

# frpc
FRPC_CONFIG_FILE=../modules/frpc/frpc.toml
