# Apply after generating .env:
#   cat .env.quality.example >> .env

SELKIES_ENCODER=x264enc,jpeg
SELKIES_FRAMERATE=8-120
SELKIES_VIDEO_BITRATE=18
SELKIES_RATE_CONTROL_MODE=cbr
SELKIES_ENABLE_RATE_CONTROL=true
SELKIES_H264_CRF=12-24
SELKIES_JPEG_QUALITY=92
SELKIES_AUDIO_BITRATE=192000
SELKIES_USE_CSS_SCALING=false
SELKIES_FORCE_ALIGNED_RESOLUTION=true
SELKIES_SCALING_DPI=96,120,144,168,192,216,240,264,288
SELKIES_USE_PAINT_OVER_QUALITY=true
SELKIES_PAINT_OVER_JPEG_QUALITY=95
SELKIES_H264_PAINTOVER_CRF=14-22
SELKIES_H264_PAINTOVER_BURST_FRAMES=8
