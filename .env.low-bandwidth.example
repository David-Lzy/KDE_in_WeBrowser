# Apply after generating .env:
#   cat .env.low-bandwidth.example >> .env

SELKIES_ENCODER=x264enc,jpeg
SELKIES_FRAMERATE=8-30
SELKIES_VIDEO_BITRATE=3
SELKIES_RATE_CONTROL_MODE=cbr
SELKIES_ENABLE_RATE_CONTROL=true
SELKIES_H264_CRF=28-40
SELKIES_JPEG_QUALITY=65
SELKIES_AUDIO_BITRATE=64000
SELKIES_USE_CSS_SCALING=true
SELKIES_FORCE_ALIGNED_RESOLUTION=true
SELKIES_SCALING_DPI=96
SELKIES_USE_PAINT_OVER_QUALITY=true
SELKIES_PAINT_OVER_JPEG_QUALITY=70
SELKIES_H264_PAINTOVER_CRF=26-36
SELKIES_H264_PAINTOVER_BURST_FRAMES=3
